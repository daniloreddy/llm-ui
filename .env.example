# ─── Auth ────────────────────────────────────────────────────────────────────

# IPs of trusted reverse proxies whose forwarded headers are accepted.
# Comma-separated. Default: 127.0.0.1 (local proxy / Cloudflare Tunnel).
# Add the proxy IP if it runs on a different machine.
# Examples:
#   TRUSTED_PROXIES=127.0.0.1
#   TRUSTED_PROXIES=127.0.0.1,10.0.0.5
TRUSTED_PROXIES=127.0.0.1

# Force the session cookie Secure flag regardless of X-Forwarded-Proto.
# Set to 1 only if you serve the app over HTTPS without a Cloudflare/proxy
# that sets X-Forwarded-Proto (e.g. direct TLS termination in uvicorn).
# Behind Cloudflare Tunnel this is NOT needed — the flag is set automatically.
# AUTH_SECURE_COOKIE=1
